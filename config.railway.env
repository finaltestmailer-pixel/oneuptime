# Railway Production Configuration
ENVIRONMENT=production
HOST=${{RAILWAY_PUBLIC_DOMAIN}}
PROVISION_SSL=true
ONEUPTIME_HTTP_PORT=3002
HTTP_PROTOCOL=https
CAPTCHA_ENABLED=false

# Security - Railway will inject these
ONEUPTIME_SECRET=${{ONEUPTIME_SECRET}}
REGISTER_PROBE_KEY=${{REGISTER_PROBE_KEY}}
DATABASE_PASSWORD=${{DATABASE_PASSWORD}}
CLICKHOUSE_PASSWORD=${{CLICKHOUSE_PASSWORD}}
REDIS_PASSWORD=${{REDIS_PASSWORD}}
ENCRYPTION_SECRET=${{ENCRYPTION_SECRET}}

# Database Configuration (Railway PostgreSQL)
DATABASE_PORT=5432
DATABASE_USERNAME=${{PGUSER}}
DATABASE_PASSWORD=${{PGPASSWORD}}
DATABASE_NAME=${{PGDATABASE}}
DATABASE_HOST=${{PGHOST}}
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Redis Configuration (Railway Redis)
REDIS_HOST=${{REDIS_HOST}}
REDIS_PORT=${{REDIS_PORT}}
REDIS_PASSWORD=${{REDIS_PASSWORD}}
REDIS_USERNAME=default

# ClickHouse Configuration (Railway will provide)
CLICKHOUSE_USER=${{CLICKHOUSE_USER}}
CLICKHOUSE_PASSWORD=${{CLICKHOUSE_PASSWORD}}
CLICKHOUSE_DATABASE=${{CLICKHOUSE_DATABASE}}
CLICKHOUSE_HOST=${{CLICKHOUSE_HOST}}
CLICKHOUSE_PORT=8123

# App Configuration
APP_PORT=3002
TELEMETRY_PORT=3403
WORKER_PORT=1445
HOME_PORT=1444

# Disable complex features for Railway
BILLING_ENABLED=false
IS_ENTERPRISE_EDITION=false
DISABLE_AUTOMATIC_INCIDENT_CREATION=false
DISABLE_AUTOMATIC_ALERT_CREATION=false

# Logging
LOG_LEVEL=INFO

# Probe Configuration
GLOBAL_PROBE_1_NAME="Railway-Probe-1"
GLOBAL_PROBE_1_DESCRIPTION="Railway deployment probe"
GLOBAL_PROBE_1_MONITORING_WORKERS=2
GLOBAL_PROBE_1_MONITOR_FETCH_LIMIT=5
GLOBAL_PROBE_1_ONEUPTIME_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
GLOBAL_PROBE_1_PORT=3874
GLOBAL_PROBE_1_KEY=${{GLOBAL_PROBE_1_KEY}}

# Disable telemetry for Railway
DISABLE_TELEMETRY_FOR_ACCOUNTS=true
DISABLE_TELEMETRY_FOR_APP=true
DISABLE_TELEMETRY_FOR_TELEMETRY=true
DISABLE_TELEMETRY_FOR_WORKER=true