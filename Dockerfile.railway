# Railway-optimized Dockerfile for OneUptime
FROM node:20-alpine

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apk add --no-cache \
    git \
    python3 \
    make \
    g++ \
    postgresql-client

# Copy package files first for better caching
COPY package*.json ./

# Install ALL dependencies including dev dependencies for TypeScript
ENV HUSKY=0
RUN npm ci --ignore-scripts

# Copy source code and config
COPY . .
COPY config.railway.env config.env

# Create non-root user
RUN addgroup -g 1001 -S nodejs
RUN adduser -S oneuptime -u 1001

# Change ownership of the app directory
RUN chown -R oneuptime:nodejs /app

USER oneuptime

# Expose port
EXPOSE 3002

# Start command using the original package.json (don't replace it)
CMD ["node", "--require", "ts-node/register", "App/Index.ts"]