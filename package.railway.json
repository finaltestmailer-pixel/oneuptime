{
    "name": "@oneuptime/railway",
    "version": "3.0.2",
    "description": "OneUptime - Railway Deployment",
    "main": "App/Index.ts",
    "type": "module",
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=8.0.0"
    },
    "scripts": {
        "start": "node --require ts-node/register App/Index.ts",
        "build": "npm run build-frontends",
        "build-frontends": "cd App && npm run build-frontends",
        "railway-deploy": "cp config.railway.env config.env && npm start"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@sendgrid/mail": "^8.1.0",
        "ejs": "^3.1.9",
        "handlebars": "^4.7.8",
        "jest": "^30.2.0",
        "mailparser": "^3.9.0",
        "nodemailer": "^6.9.7",
        "ts-node": "^10.9.2",
        "twilio": "^4.20.0",
        "typeorm": "^0.3.28",
        "xml-crypto": "^3.2.0",
        "xml2js": "^0.6.2",
        "xmldom": "^0.6.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.11",
        "@types/node": "^17.0.31",
        "@types/nodemailer": "^6.4.14",
        "@types/xml2js": "^0.4.14",
        "@types/xmldom": "^0.1.34",
        "typescript": "^5.9.2"
    }
}